{
  "name": "@aquario/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cf:deploy": "wrangler deploy",
    "cf:d1:apply:local": "wrangler d1 migrations apply aquario-db --local",
    "cf:d1:apply:remote": "wrangler d1 migrations apply aquario-db --remote"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.5",
    "hono": "^4.6.5",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.73.0"
  }
}
