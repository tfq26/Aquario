{
  "name": "aquario-api",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-16",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "APP_ORIGIN": "http://localhost:5173",
    "API_ORIGIN": "http://localhost:8787",
    "COOKIE_SECURE": "false",
    "GEMINI_MODEL": "gemini-3.1-flash"
  },
  "d1_databases": [
    {
      "binding": "APP_DB",
      "database_name": "aquario-db",
      "database_id": "49e8aed6-5d4e-4972-a95c-96efc878a74f"
    }
  ],
  "r2_buckets": [
    {
      "binding": "RESUME_BUCKET",
      "bucket_name": "aquario-resumes"
    }
  ],
  "env": {
    "production": {
      "vars": {
        "APP_ORIGIN": "https://d974f8b2.aquario-web.pages.dev",
        "API_ORIGIN": "https://aquario-api.aquario-api.workers.dev",
        "COOKIE_SECURE": "true",
        "GEMINI_MODEL": "gemini-3.1-flash"
      }
    }
  }
}
